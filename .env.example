# compose-pulse sample environment file
# Copy this file to `.env` and edit values for your NAS.

# App auth / DIUN webhook secret (required by the app)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password
DIUN_WEBHOOK_SECRET=change-me-diun-webhook-secret
# TIP: DIUN itself is required only when you enable auto-update targets
# TIP: generate/update with ./scripts/generate_diun_secret.sh
# Optional (default false): expose full secret in /api/diun/webhook/config
# WEBHOOK_CONFIG_SHOW_SECRET=false

# Persistent app data on NAS (required)
APP_DATA_BIND_DIR=data

# Optional when using docker-compose.image.yml
# COMPOSEPULSE_IMAGE=changjo/composepulse:v0.1.0

# Optional security hardening
# LOGIN_RATE_LIMIT_WINDOW_SECONDS=600
# LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
# LOGIN_RATE_LIMIT_LOCK_SECONDS=900
# DASHBOARD_SSE_MAX_CONNECTIONS=20

# Optional pull retry tuning
# PULL_RETRY_MAX_ATTEMPTS=3
# PULL_RETRY_DELAY_SECONDS=2

# Optional Web Push (default disabled)
# WEB_PUSH_ENABLED=false
# WEB_PUSH_VAPID_PUBLIC_KEY=
# WEB_PUSH_VAPID_PRIVATE_KEY=
# TIP: generate/update with ./scripts/generate_vapid_keys.sh
# WEB_PUSH_SUBJECT=mailto:admin@example.com
